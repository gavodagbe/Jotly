# Compose project/container prefix (avoid collisions with other apps)
COMPOSE_PROJECT_NAME=jotly_prod

# Domain and frontend bind port for host Nginx upstream
APP_DOMAIN=jotly.godwinavodagbe.com
FRONTEND_HOST_PORT=3100

# PostgreSQL
POSTGRES_DB=jotly
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Backend runtime
LOG_LEVEL=info
AUTH_SESSION_TTL_HOURS=168
DATABASE_URL_DOCKER=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/jotly
AI_ASSISTANT_PROVIDER=heuristic
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE_URL=https://api.openai.com/v1
AI_ASSISTANT_TIMEOUT_MS=10000
FRONTEND_ORIGIN=https://jotly.godwinavodagbe.com
# Optional: required when AI_ASSISTANT_PROVIDER=openai
# OPENAI_API_KEY=
# Optional: required to enable Google Calendar integration
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://jotly.godwinavodagbe.com/backend-api/google-calendar/callback
# GOOGLE_CALENDAR_ENCRYPTION_KEY=

# Frontend build/runtime API URLs
FRONTEND_BACKEND_API_BASE_URL=http://backend:3001
NEXT_PUBLIC_API_BASE_URL=https://jotly.godwinavodagbe.com/backend-api
