# Compose project/container prefix (avoid collisions with other apps)
COMPOSE_PROJECT_NAME=jotly_prod

# Domain and frontend bind port for host Nginx upstream
APP_DOMAIN=jotly.godwinavodagbe.com
FRONTEND_HOST_PORT=3100

# PostgreSQL
POSTGRES_DB=jotly
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Backend runtime
LOG_LEVEL=info
AUTH_SESSION_TTL_HOURS=168
DATABASE_URL_DOCKER=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/jotly

# Frontend build/runtime API URLs
FRONTEND_BACKEND_API_BASE_URL=http://backend:3001
NEXT_PUBLIC_API_BASE_URL=https://jotly.godwinavodagbe.com/backend-api
