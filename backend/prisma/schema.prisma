generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  todo
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
}

enum RecurrenceFrequency {
  daily
  weekly
  monthly
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  displayName  String?
  preferredLocale String @default("en")
  preferredTimeZone String?
  sessions     Session[]
  passwordResetTokens PasswordResetToken[]
  tasks        Task[]
  dayAffirmations DayAffirmation[]
  dayBilans    DayBilan[]
  assistantSearchDocuments AssistantSearchDocument[]
  gamingTrackChallengeClaims GamingTrackChallengeClaim[]
  gamingTrackStreakProtectionUsages GamingTrackStreakProtectionUsage[]
  gamingTrackNudgeDismissals GamingTrackNudgeDismissal[]
  googleCalendarConnections GoogleCalendarConnection[]
  calendarEvents CalendarEvent[]
  reminders    Reminder[]
  notes        Note[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model Task {
  id                       String              @id @default(cuid())
  userId                   String
  rolledFromTaskId         String?
  title                    String
  description              String?
  status                   TaskStatus
  targetDate               DateTime            @db.Date
  dueDate                  DateTime?           @db.Date
  priority                 TaskPriority
  project                  String?
  plannedTime              Int?
  recurrenceSourceTaskId   String?
  recurrenceOccurrenceDate DateTime?           @db.Date
  calendarEventId          String?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  completedAt              DateTime?
  cancelledAt              DateTime?
  comments                 TaskComment[]
  attachments              TaskAttachment[]
  recurrenceRule           TaskRecurrenceRule?
  user                     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarEvent            CalendarEvent?      @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  rolledFromTask           Task?               @relation("TaskCarryOverInstances", fields: [rolledFromTaskId], references: [id], onDelete: SetNull)
  carryOverInstances       Task[]              @relation("TaskCarryOverInstances")
  sourceTask               Task?               @relation("TaskRecurrenceInstances", fields: [recurrenceSourceTaskId], references: [id], onDelete: SetNull)
  recurrenceInstances      Task[]              @relation("TaskRecurrenceInstances")

  @@index([userId, targetDate])
  @@index([userId, dueDate])
  @@index([userId, status])
  @@index([targetDate])
  @@index([dueDate])
  @@index([status])
  @@index([updatedAt])
  @@index([rolledFromTaskId])
  @@index([recurrenceSourceTaskId])
  @@index([calendarEventId])
  @@unique([rolledFromTaskId, targetDate])
  @@unique([recurrenceSourceTaskId, recurrenceOccurrenceDate])
}

model DayAffirmation {
  id          String   @id @default(cuid())
  userId      String
  targetDate  DateTime @db.Date
  text        String
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetDate])
  @@index([userId, targetDate])
}

model DayBilan {
  id             String   @id @default(cuid())
  userId         String
  targetDate     DateTime @db.Date
  mood           Int?
  wins           String?
  blockers       String?
  lessonsLearned String?
  tomorrowTop3   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetDate])
  @@index([userId, targetDate])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model TaskAttachment {
  id          String   @id @default(cuid())
  taskId      String
  name        String
  url         String
  contentType String?
  sizeBytes   Int?
  createdAt   DateTime @default(now())
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model TaskRecurrenceRule {
  id        String              @id @default(cuid())
  taskId    String              @unique
  frequency RecurrenceFrequency
  interval  Int                 @default(1)
  weekdays  Int[]               @default([])
  endsOn    DateTime?           @db.Date
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  task      Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([endsOn])
}

model GamingTrackChallengeClaim {
  id                String   @id @default(cuid())
  userId            String
  challengeId       String
  challengeWeekStart DateTime @db.Date
  rewardXp          Int
  claimedAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId, challengeWeekStart])
  @@index([userId, challengeWeekStart])
}

model GamingTrackStreakProtectionUsage {
  id        String   @id @default(cuid())
  userId    String
  usedOn    DateTime @db.Date
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, usedOn])
  @@index([userId, usedOn])
}

model GamingTrackNudgeDismissal {
  id         String   @id @default(cuid())
  userId     String
  nudgeId    String
  dismissedOn DateTime @db.Date
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nudgeId, dismissedOn])
  @@index([userId, dismissedOn])
}

model GoogleCalendarConnection {
  id                 String    @id @default(cuid())
  userId             String
  googleAccountEmail String
  accessToken        String
  refreshToken       String
  tokenExpiresAt     DateTime
  calendarId         String    @default("primary")
  color              String    @default("#6366f1")
  lastSyncToken      String?
  lastSyncedAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  events             CalendarEvent[]

  @@unique([userId, googleAccountEmail])
  @@index([userId])
}

model CalendarEvent {
  id               String             @id @default(cuid())
  userId           String
  connectionId     String
  googleEventId    String
  title            String
  description      String?
  location         String?
  startTime        DateTime
  endTime          DateTime
  isAllDay         Boolean            @default(false)
  startDate        DateTime?          @db.Date
  endDate          DateTime?          @db.Date
  status           String             @default("confirmed")
  htmlLink         String?
  attendees        String?
  organizer        String?
  recurringEventId String?
  syncedAt         DateTime           @default(now())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection       GoogleCalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  notes            CalendarEventNote[]
  linkedNote       Note?              @relation("CalendarEventLinkedNote")
  linkedTasks      Task[]

  @@unique([connectionId, googleEventId])
  @@index([connectionId])
  @@index([userId, startTime])
  @@index([userId, startDate])
}

model CalendarEventNote {
  id              String        @id @default(cuid())
  calendarEventId String        @unique
  userId          String
  body            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  attachments     CalendarEventNoteAttachment[]

  @@index([userId])
}

model CalendarEventNoteAttachment {
  id                  String            @id @default(cuid())
  calendarEventNoteId String
  userId              String
  name                String
  url                 String
  contentType         String?
  sizeBytes           Int?
  createdAt           DateTime          @default(now())
  calendarEventNote   CalendarEventNote @relation(fields: [calendarEventNoteId], references: [id], onDelete: Cascade)

  @@index([calendarEventNoteId])
  @@index([userId])
}

model Reminder {
  id          String               @id @default(cuid())
  userId      String
  title       String
  description String?
  project     String?
  assignees   String?
  remindAt    DateTime
  isFired     Boolean              @default(false)
  firedAt     DateTime?
  isDismissed Boolean              @default(false)
  dismissedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments ReminderAttachment[]

  @@index([userId, remindAt])
  @@index([userId, isFired, isDismissed])
}

model ReminderAttachment {
  id          String   @id @default(cuid())
  reminderId  String
  userId      String
  name        String
  url         String
  contentType String?
  sizeBytes   Int?
  createdAt   DateTime @default(now())
  reminder    Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([reminderId, createdAt])
  @@index([userId])
}

model Note {
  id          String           @id @default(cuid())
  userId      String
  calendarEventId String?
  title       String?
  body        String
  color       String?
  targetDate  DateTime?        @db.Date
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarEvent CalendarEvent? @relation("CalendarEventLinkedNote", fields: [calendarEventId], references: [id], onDelete: SetNull)
  attachments NoteAttachment[]

  @@index([userId])
  @@unique([calendarEventId])
  @@index([userId, targetDate])
  @@index([userId, createdAt])
  @@index([userId, calendarEventId])
}

model NoteAttachment {
  id          String   @id @default(cuid())
  noteId      String
  userId      String
  name        String
  url         String
  contentType String?
  sizeBytes   Int?
  createdAt   DateTime @default(now())
  note        Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt])
  @@index([userId])
}

model AssistantSearchDocument {
  id                String   @id @default(cuid())
  userId            String
  sourceType        String
  sourceId          String
  title             String?
  bodyText          String
  metadataJson      Json?
  contentHash       String
  sourceUpdatedAt   DateTime
  extractionStatus  String?
  extractionWarning String?
  embeddingModel    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sourceType, sourceId])
  @@index([userId, sourceType])
  @@index([userId, updatedAt])
  @@index([userId, sourceUpdatedAt])
}
