generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  todo
  in_progress
  done
  cancelled
}

enum TaskPriority {
  low
  medium
  high
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus
  targetDate  DateTime     @db.Date
  priority    TaskPriority
  project     String?
  plannedTime Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  completedAt DateTime?
  cancelledAt DateTime?

  @@index([targetDate])
  @@index([status])
  @@index([updatedAt])
}
