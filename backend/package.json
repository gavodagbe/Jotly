{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "node --import tsx --test src/routes/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:verify-task-ownership": "tsx prisma/verify-task-ownership-backfill.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.23",
    "prisma": "^6.19.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
