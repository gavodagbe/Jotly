FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG BACKEND_API_BASE_URL=http://backend:3001
ARG NEXT_PUBLIC_API_BASE_URL=https://jotly.godwinavodagbe.com/backend-api
ENV BACKEND_API_BASE_URL=${BACKEND_API_BASE_URL}
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}

RUN npm run build

ENV NODE_ENV=production
EXPOSE 3000

CMD ["npm", "run", "start", "--", "--hostname", "0.0.0.0", "--port", "3000"]
