# PostgreSQL (Docker Compose defaults)
POSTGRES_DB=jotly
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Backend (when running outside Docker)
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jotly
AUTH_SESSION_TTL_HOURS=168
AI_ASSISTANT_PROVIDER=heuristic
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE_URL=https://api.openai.com/v1
AI_ASSISTANT_TIMEOUT_MS=10000
# Optional: required when AI_ASSISTANT_PROVIDER=openai
# OPENAI_API_KEY=

# Backend (when running inside Docker Compose)
DATABASE_URL_DOCKER=postgresql://postgres:postgres@postgres:5432/jotly

# Frontend (browser-visible API URL)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Frontend (server-side rewrite target inside Docker Compose)
FRONTEND_BACKEND_API_BASE_URL=http://backend:3001
