# PostgreSQL (Docker Compose defaults)
POSTGRES_DB=jotly
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Backend (when running outside Docker)
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jotly

# Backend (when running inside Docker Compose)
DATABASE_URL_DOCKER=postgresql://postgres:postgres@postgres:5432/jotly

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
